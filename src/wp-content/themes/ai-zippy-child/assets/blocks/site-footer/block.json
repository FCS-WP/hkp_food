{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/site-footer",
  "version": "1.0.0",
  "title": "Site Footer",
  "category": "ai-zippy",
  "icon": "layout",
  "description": "Full-width footer with contact info, centre logo image, social icons, and navigation links.",
  "keywords": [
    "footer",
    "contact",
    "social",
    "navigation",
    "logo"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "address": {
      "type": "string",
      "default": "352 Joo Chiat Road\nSingapore 427599"
    },
    "email": {
      "type": "string",
      "default": "connect@hokeepau.com"
    },
    "phone": {
      "type": "string",
      "default": "+65 6742 1468"
    },
    "logoId": {
      "type": "number",
      "default": 0
    },
    "logoUrl": {
      "type": "string",
      "default": ""
    },
    "logoAlt": {
      "type": "string",
      "default": "Ho Kee Pau"
    },
    "socialIcons": {
      "type": "array",
      "default": [
        {
          "url": "#",
          "imageId": 0,
          "imageUrl": "",
          "imageAlt": "Facebook"
        },
        {
          "url": "#",
          "imageId": 0,
          "imageUrl": "",
          "imageAlt": "Instagram"
        },
        {
          "url": "#",
          "imageId": 0,
          "imageUrl": "",
          "imageAlt": "TikTok"
        }
      ]
    },
    "navLinks": {
      "type": "array",
      "default": [
        {
          "label": "Home",
          "url": "/"
        },
        {
          "label": "About Us",
          "url": "/about"
        },
        {
          "label": "Shop",
          "url": "/shop"
        },
        {
          "label": "Contact Us",
          "url": "/contact"
        },
        {
          "label": "Privacy Policy",
          "url": "/privacy-policy"
        },
        {
          "label": "Terms & Conditions",
          "url": "/terms"
        }
      ]
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}