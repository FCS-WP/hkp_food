{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/our-story",
  "version": "1.0.0",
  "title": "Our Story",
  "category": "ai-zippy",
  "icon": "columns",
  "description": "A two-column story section with a portrait image on the left and editable content blocks on the right.",
  "keywords": [
    "story",
    "about",
    "content",
    "history"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "leftWidth": {
      "type": "number",
      "default": 30
    },
    "rightWidth": {
      "type": "number",
      "default": 70
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}