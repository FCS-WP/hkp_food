{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/product-showcase",
  "version": "1.0.0",
  "title": "Product Showcase",
  "category": "ai-zippy",
  "icon": "products",
  "description": "Display a showcase of WooCommerce products with circular images and descriptions.",
  "keywords": [
    "products",
    "woocommerce",
    "showcase",
    "featured"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Explore Our Favourites"
    },
    "description": {
      "type": "string",
      "default": "A selection of our most-loved paus and dim sum, freshly made, packed with flavour, and enjoyed across Singapore."
    },
    "productIds": {
      "type": "array",
      "default": []
    },
    "buttonText": {
      "type": "string",
      "default": "Shop Now"
    },
    "buttonUrl": {
      "type": "string",
      "default": "/shop"
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}