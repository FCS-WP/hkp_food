{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy-child/features",
	"version": "1.0.0",
	"title": "Features",
	"category": "ai-zippy",
	"icon": "grid-view",
	"description": "A 3-column features section with icons, headings, and descriptions.",
	"keywords": ["features", "benefits", "highlights", "services"],
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"feature1IconId": {
			"type": "number",
			"default": 0
		},
		"feature1IconUrl": {
			"type": "string",
			"default": ""
		},
		"feature1IconAlt": {
			"type": "string",
			"default": ""
		},
		"feature1Heading": {
			"type": "string",
			"default": "Enjoy free shipping on orders $200+"
		},
		"feature1Description": {
			"type": "string",
			"default": "$150 minimum purchase required"
		},
		"feature2IconId": {
			"type": "number",
			"default": 0
		},
		"feature2IconUrl": {
			"type": "string",
			"default": ""
		},
		"feature2IconAlt": {
			"type": "string",
			"default": ""
		},
		"feature2Heading": {
			"type": "string",
			"default": "Islandwide Presence"
		},
		"feature2Description": {
			"type": "string",
			"default": "7 Outlets across Singapore"
		},
		"feature3IconId": {
			"type": "number",
			"default": 0
		},
		"feature3IconUrl": {
			"type": "string",
			"default": ""
		},
		"feature3IconAlt": {
			"type": "string",
			"default": ""
		},
		"feature3Heading": {
			"type": "string",
			"default": "Traditional Handmade Dimsum"
		},
		"feature3Description": {
			"type": "string",
			"default": "Steamed Fried & Perfected"
		}
	},
	"textdomain": "ai-zippy-child",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
