{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy-child/contact-us",
	"version": "1.0.0",
	"title": "Contact Us Section",
	"category": "ai-zippy",
	"icon": "email",
	"description": "Contact page section with title, contact card, and contact form.",
	"keywords": ["contact", "form", "address", "social"],
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"address": { "type": "string", "default": "352 Joo Chiat Road\nSingapore 427599" },
		"email": { "type": "string", "default": "connect@hokeepau.com" },
		"phone": { "type": "string", "default": "+65 6742 1468" },
		"socialIcons": {
			"type": "array",
			"default": [
				{ "url": "#", "imageId": 0, "imageUrl": "", "imageAlt": "Instagram" },
				{ "url": "#", "imageId": 0, "imageUrl": "", "imageAlt": "Facebook" },
				{ "url": "#", "imageId": 0, "imageUrl": "", "imageAlt": "TikTok" }
			]
		}
	},
	"textdomain": "ai-zippy-child",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
